# Configuração de Banco de Dados (PostgreSQL é OBRIGATÓRIO)
KALLIA_PG_URL=postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable
KALLIA_PG_NAMESPACE=kallia

# Usuário Admin e Projeto Inicial (Criados automaticamente no primeiro deploy se a base estiver limpa)
KALLIA_ADMIN_EMAIL=admin@kallia.com
KALLIA_ADMIN_PASSWORD=123456
KALLIA_INITIAL_PROJECT_NAME=Projeto Inicial
KALLIA_INITIAL_PROJECT_PLAN=expert

# Limites e Autenticação
KALLIA_MAX_CALLS=8
# KALLIA_API_KEY=sua_chave_secreta_aqui

# Nível de log (debug|info|warn|error)
# KALLIA_LOG_LEVEL=info

# CORS: origens permitidas separadas por vírgula
# KALLIA_CORS_ORIGINS=https://calls.seudominio.com,https://chat.seudominio.com

# Configurações de Mídia VoIP (WebRTC)
# KALLIA_PUBLIC_IP=auto
# KALLIA_UDP_PORT=50000

# Chatwoot
Chatwoot_url=https://chat.seudominio.com
account_id=1
inbox_id=1
acess_token=COLOQUE_SEU_TOKEN_AQUI
inbox_identifier=COLOQUE_SEU_INBOX_IDENTIFIER_AQUI
